APP_NAME=Campus Incidents API
APP_ENV=development
APP_DEBUG=true

DATABASE_URL=postgresql+psycopg2://campus_app:YOUR_DB_PASSWORD@localhost:5432/campus_incidents
AUTO_CREATE_SCHEMA=false

JWT_SECRET=change-this-secret-in-production
JWT_EXP_MINUTES=480
CORS_ORIGINS=http://localhost:3000

LOCAL_STORAGE_PATH=./data/evidences
MAX_IMAGE_SIZE_MB=10

GEMINI_API_KEY=AIzaSyC0KbPYETFt1CDRCXAMsIFb0_qZvHyze9I
GEMINI_MODEL=gemini-2.5-flash
GEMINI_PROMPT_VERSION=mvp-v1
GEMINI_THINKING_BUDGET=0

SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=alerts@campus.local
DEFAULT_ALERT_EMAIL=seguridad@campus.edu
DASHBOARD_BASE_URL=http://localhost:3000/dashboard

WORKER_POLL_SECONDS=2.0
CLASSIFICATION_RETRY_DELAY_SECONDS=120
NOTIFICATION_RETRY_DELAY_SECONDS=60
